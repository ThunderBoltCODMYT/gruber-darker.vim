# Vim/Neovim theme repository .gitignore
# =====================================

# OS-specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.swp
*.swo
*~

# IDE/Editor files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.tmproj
*.tmproject
tmtags

# Temporary files
*.tmp
*.temp
.cache/
*.log

# Build artifacts (if any)
build/
dist/
*.zip
*.tar.gz

# Screenshots or generated images (uncomment if you add them)
# screenshots/
# assets/

# Documentation build artifacts
doc/tags
*.html

# Test files (if you add tests later)
test/
*.test
*.spec

# Node modules (if you add any tooling)
node_modules/

# Backup files
*.bak
*.backup
*.orig